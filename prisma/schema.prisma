generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SACCO {
  id        String   @id @default(cuid())
  name      String
  region    String   @default("Mombasa") // Mombasa, Nairobi, Kisumu, etc.
  code      String?  // e.g. "LKN-EXP", "CITIHOPA"
  buses     Bus[]
  routes    Route[]
  owner     Owner?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bus {
  id               String   @id @default(cuid())
  name             String
  registrationNumber String  @unique
  totalSeats       Int      @default(14)
  layoutType       String   @default("matatu_14") // matatu_14, coaster_33, van_11
  saccoid          String
  sacco            SACCO    @relation(fields: [saccoid], references: [id])
  seats            Seat[]
  trips            Trip[]
  routeId          String?
  route            Route?   @relation(fields: [routeId], references: [id])
  gpsHistory       GPSHistory[]
  // Live state (last known)
  lastLat          Float?
  lastLng          Float?
  lastSpeed        Float?   @default(0)
  lastHeading      Float?   @default(0)
  lastGpsAt        DateTime?
  isTracking       Boolean  @default(false)
  isOffRoute       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([saccoid])
}

model Route {
  id        String   @id @default(cuid())
  name      String   // human label, e.g. "Likoni → Mombasa CBD"
  code      String?  // Nairobi-style numbered route, e.g. "33", "110", "237"
  region    String   @default("Mombasa") // Nairobi, Mombasa, Kisumu...
  saccoId   String
  sacco     SACCO    @relation(fields: [saccoId], references: [id])
  buses     Bus[]
  stops     Stop[]
  // Optional bounding-box-ish metadata for fleet map zoom
  centerLat Float?
  centerLng Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saccoId])
  @@index([code, region])
}

model Stop {
  id        String   @id @default(cuid())
  name      String
  order     Int
  isStage   Boolean  @default(true)
  lat       Float?
  lng       Float?
  fareFromOrigin Float? @default(0) // suggested fare from route origin
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routeId])
}

model Seat {
  id          String   @id @default(cuid())
  number      Int
  row         Int     @default(0)  // physical row in the bus
  col         Int     @default(0)  // physical column (for layout rendering)
  busId       String
  bus         Bus      @relation(fields: [busId], references: [id])
  isOccupied  Boolean  @default(false)
  passenger   Passenger?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([number, busId])
  @@index([busId])
}

model Passenger {
  id             String   @id @default(cuid())
  name           String?
  phone          String?
  seat           Seat?    @relation(fields: [seatId], references: [id])
  seatId         String?  @unique
  busId          String
  boardingStop   String
  alightingStop  String
  alightingStopOrder Int @default(0)
  fare           Float    @default(0)
  paymentStatus  String   @default("unpaid") // unpaid, pending, paid
  paymentMethod  String?  // mpesa, nfc, qr, cash, card
  boardedAt      DateTime @default(now())
  alightedAt     DateTime?
  tripId         String?
  trip           Trip?    @relation(fields: [tripId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([busId])
}

model Trip {
  id              String   @id @default(cuid())
  busId           String
  bus             Bus      @relation(fields: [busId], references: [id])
  currentStopIndex Int     @default(0)
  status          String   @default("active") // active, completed
  totalPassengers Int      @default(0)
  totalRevenue    Float    @default(0)
  passengers      Passenger[]
  startTime       DateTime @default(now())
  endTime         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([busId])
}

model Transaction {
  id           String   @id @default(cuid())
  passengerId  String
  amount       Float
  method       String   // mpesa, nfc, qr, cash, card
  status       String   @default("pending") // pending, confirmed, failed
  reference    String?
  createdAt    DateTime @default(now())
  syncedAt     DateTime?
}

model NotificationLog {
  id        String   @id @default(cuid())
  type      String   // passenger_boarded, passenger_alighting, payment_received, stop_approaching
  message   String
  target    String   // driver, conductor, passenger, owner
  busId     String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Owner is the auth principal in multi-SACCO mode.
// For demo we look up the first Owner, in production this would be
// tied to a session/JWT carrying ownerId.
model Owner {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  saccoId   String   @unique
  sacco     SACCO    @relation(fields: [saccoId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GPSHistory {
  id        String   @id @default(cuid())
  busId     String
  bus       Bus      @relation(fields: [busId], references: [id])
  lat       Float
  lng       Float
  speed     Float    @default(0)
  heading   Float    @default(0)
  accuracy  Float?   // GPS accuracy in meters
  source    String   @default("tablet") // tablet, simulated, manual
  isOffRoute Boolean @default(false)
  offRouteDistance Float? @default(0) // meters from nearest route point
  createdAt DateTime @default(now())

  @@index([busId, createdAt])
  @@index([createdAt])
}
